# Daemon (the copilot --headless process)
DAEMON_HOST=127.0.0.1
DAEMON_PORT=4321
COPILOT_BIN=copilot

# Gateway (the WS server surfaces connect to)
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=8787

# Optional: override the default project root (otherwise inferred from cwd)
# PROJECT_ROOT=/home/you/Projects/tower
