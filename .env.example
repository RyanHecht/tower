# =============================================================================
# Gateway (the WebSocket server surfaces connect to)
# =============================================================================
# What the TUI / mobile app / etc. point at. The container publishes the
# gateway on host loopback only; bind it to a non-loopback interface ONLY if
# you've put TLS + auth in front of it.
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=8787

# =============================================================================
# Container-internal (rarely need to touch)
# =============================================================================
# Inside the container, the gateway binds 0.0.0.0:8787 (overridden in
# docker-compose.yml) and is exposed to the host as 127.0.0.1:8787. The
# daemon listens loopback-only inside the container and is never exposed.
# DAEMON_HOST=127.0.0.1
# DAEMON_PORT=4321

# Override the project root inside the container (defaults to /tower).
# PROJECT_ROOT=/tower
