{
  "name": "tower",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Long-lived Copilot CLI daemon + WebSocket gateway",
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "dev": "npm run dev -w @tower/gateway",
    "start": "npm run start -w @tower/gateway",
    "tui": "npm run dev -w @tower/tui",
    "daemon:start": "bash scripts/daemon-start.sh",
    "daemon:stop": "bash scripts/daemon-stop.sh",
    "daemon:status": "bash scripts/daemon-status.sh",
    "token": "bash scripts/token.sh"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  }
}
