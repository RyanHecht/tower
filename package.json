{
  "name": "tower",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Long-lived Copilot CLI daemon + WebSocket gateway",
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "dev": "npm run dev -w @tower/gateway",
    "start": "npm run start -w @tower/gateway",
    "tui": "npm run dev -w @tower/tui",
    "container:build": "bash scripts/container-build.sh",
    "container:start": "bash scripts/container-start.sh",
    "container:stop": "bash scripts/container-stop.sh",
    "container:status": "bash scripts/container-status.sh",
    "container:logs": "bash scripts/container-logs.sh",
    "container:auth": "bash scripts/container-auth.sh",
    "container:shell": "bash scripts/container-shell.sh",
    "token": "bash scripts/token.sh"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  }
}
